# Copia in .env.local e compila.

# --- Supabase (per la versione cloud/multi-utente) ---
# Da Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NB: l'app NON usa la chiave service_role (tutto passa da RLS con la anon key
# + cookie di sessione). Non aggiungerla qui: bypasserebbe la RLS ed è pericolosa
# se esposta.

# --- AI (opzionale) ---
# Fallback per fatture non-Bambu. In alternativa puoi impostare provider e
# chiave dall'app (Impostazioni → Estrazione AI fatture).
ANTHROPIC_API_KEY=
